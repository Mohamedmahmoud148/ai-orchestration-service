# FastAPI Environment
ENVIRONMENT=development
PORT=8000

# ─── OpenRouter (Primary AI Provider) ──────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional fallback models (OpenRouter slugs — see https://openrouter.ai/models)
# If left empty, defaults below are used:
OPENROUTER_FALLBACK_MODEL_1=openai/gpt-4o-mini
OPENROUTER_FALLBACK_MODEL_2=mistralai/mistral-7b-instruct

# ─── .NET Backend ──────────────────────────────────────────────────
BACKEND_BASE_URL=https://universitymanagementsystem-production-e58e.up.railway.app

# ─── Redis (optional — for memory store) ───────────────────────────
REDIS_URL=
